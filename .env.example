# Environment Variables for Docker Compose
# Copy this file to .env and update with your values

# Clerk Configuration
VITE_CLERK_PUBLISHABLE_KEY=pk_test_dGlkeS1sbGFtYS0yNC5jbGVyay5hY2NvdW50cy5kZXYk

# Encryption (Optional)
ENCRYPTION_SECRET_KEY=your_encryption_key_here

# MongoDB (Optional - defaults are fine for local development)
# MONGO_INITDB_ROOT_USERNAME=admin
# MONGO_INITDB_ROOT_PASSWORD=password

# Email Configuration (Already set in docker-compose.yml, override if needed)
# SPRING_MAIL_USERNAME=your_email_username
# SPRING_MAIL_PASSWORD=your_email_password

# Razorpay Configuration (Already set in docker-compose.yml, override if needed)
# RAZORPAY_KEY_ID=your_razorpay_key
# RAZORPAY_KEY_SECRET=your_razorpay_secret
# RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
